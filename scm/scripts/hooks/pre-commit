#!/usr/bin/env bash
# Pre-commit hook — fail-fast on first failing check.
# Installed by bootstrap.sh / bootstrap.ps1 via `git config core.hooksPath scripts/hooks`.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCM_DIR="$REPO_ROOT/scm"

echo "pre-commit ── configbuilder ──"
cd "$SCM_DIR"

echo "  1/4 fmt..."
cargo fmt --all -- --check

echo "  2/4 clippy..."
cargo clippy --all-targets -- -D warnings

echo "  3/4 arch audit..."
# Two rules are intentionally excluded from this gate (swearchitect #237-#240):
#   lib_no_direct_api_impl_reexport   — *Impl types must stay in api/ (saf_returns_api_types)
#   saf_no_inherent_impl_on_api_type  — build_loader() must be inherent (api_no_core_import)
# These three rules deadlock each other; a BuilderFinalizer trait is the proper fix.
ARCH_OUT=$(arch audit --rs 2>&1)
ARCH_EXIT=$?
printf '%s\n' "$ARCH_OUT"
if [ $ARCH_EXIT -ne 0 ]; then
  UNEXPECTED=$(printf '%s\n' "$ARCH_OUT" | grep "\[FAIL\]" | \
    grep -v "lib_no_direct_api_impl_reexport\|saf_no_inherent_impl_on_api_type")
  if [ -n "$UNEXPECTED" ]; then
    echo "  arch audit: unexpected failures:"
    printf '%s\n' "$UNEXPECTED"
    exit 1
  fi
  echo "  arch audit: 2 pre-existing violations acknowledged (swearchitect #237-#240)"
fi

echo "  4/4 cargo audit..."
cargo audit --deny unsound --deny yanked

echo "pre-commit: all checks passed."
