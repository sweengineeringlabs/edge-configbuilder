#!/usr/bin/env bash
# Pre-commit hook — fail-fast on first failing check.
# Installed by bootstrap.sh / bootstrap.ps1 via `git config core.hooksPath scripts/hooks`.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCM_DIR="$REPO_ROOT/scm"

echo "pre-commit ── configbuilder ──"
cd "$SCM_DIR"

echo "  1/4 fmt..."
cargo fmt --all -- --check

echo "  2/4 clippy..."
cargo clippy --all-targets -- -D warnings

echo "  3/4 arch audit..."
ARCH_OUT=$(arch audit --rs 2>&1)
ARCH_EXIT=$?
printf '%s\n' "$ARCH_OUT"
if [ $ARCH_EXIT -ne 0 ]; then
  echo "  arch audit: FAILED"
  exit 1
fi

echo "  4/4 cargo audit..."
cargo audit --deny unsound --deny yanked

echo "pre-commit: all checks passed."
